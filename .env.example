# Database - must match docker-compose postgres credentials
DATABASE_URL="postgresql://user:password@localhost:5432/spaceflow"

# Bearer token for protected endpoints (use in header: Authorization: Bearer <token>)
AUTH_BEARER_TOKEN="your-test-bearer-token"

# Optional: API port (default 3000)
# PORT=3000

# MQTT broker (used by MQTT consumer for telemetry). If unset, the MQTT client will not connect.
MQTT_BROKER_URL="mqtt://localhost:1883"
# Optional MQTT client id
# MQTT_CLIENT_ID="spaceflow-api"
