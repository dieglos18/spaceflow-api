generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Place {
  id           String        @id @default(cuid())
  name         String        @unique
  location     String
  spaces       Space[]
  reservations Reservation[]
}

model Space {
  id          String        @id @default(cuid())
  placeId     String
  place       Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  name        String
  reference   String
  capacity    Int?
  description String?
  reservations Reservation[]
  telemetry   Telemetry[]
  @@unique([placeId, name])
  @@index([placeId])
}

model Reservation {
  id               String   @id @default(cuid())
  spaceId          String
  space            Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  placeId          String?
  place            Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)
  clientEmail      String
  reservationDate  DateTime
  startTime        String
  endTime          String
  @@index([spaceId])
  @@index([reservationDate])
}

model Telemetry {
  id         String   @id @default(cuid())
  spaceId    String
  space      Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  peopleCount Int
  temperature Float?
  humidity    Float?
  co2         Float?
  battery     Float?
  timestamp   DateTime
  @@index([spaceId])
  @@index([timestamp])
}
